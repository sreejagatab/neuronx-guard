# NeuronX Guard Configuration

# GitHub App Credentials (from https://github.com/settings/apps)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=neuronx-guard.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NeuronX API (the brain)
NEURONX_API_URL=https://neuronx.jagatab.uk
NEURONX_API_KEY=

# Server
GUARD_PORT=9000
GUARD_HOST=0.0.0.0

# Limits
MAX_DIFF_SIZE=50000
MAX_FILES_PER_REVIEW=20
MAX_REVIEW_COMMENTS=15

# Features
ENABLE_LLM_REVIEW=true
ENABLE_PATTERN_SEARCH=true
ENABLE_AST_CHECK=true
ENABLE_SECURITY_SCAN=true
