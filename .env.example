# NeuronX Guard Configuration
# Copy to .env and fill in your values

# GitHub App Credentials (from https://github.com/settings/apps/your-app)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=your-app.pem
GITHUB_WEBHOOK_SECRET=

# OAuth (for SaaS login)
GUARD_GITHUB_CLIENT_ID=
GUARD_GITHUB_CLIENT_SECRET=
GUARD_JWT_SECRET=

# NeuronX API
NEURONX_API_URL=https://neuronx.jagatab.uk
GUARD_BASE_URL=https://your-domain.com

# Stripe Billing (from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# Database (PostgreSQL recommended, SQLite fallback)
DATABASE_URL=

# Redis (for job queue, auto-retry)
REDIS_URL=redis://localhost:6379/0
